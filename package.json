{
  "name": "sickfits",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && node --env-file=.env --watch src/server.js",
    "build:css": "npx @tailwindcss/cli -i ./public/css/app.css -o ./public/css/tailwind.css --minify",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/config": "^7.0.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.14.1",
    "prisma": "^7.0.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.4",
    "tailwindcss": "^4.1.4"
  }
}
